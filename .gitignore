node_modules/
.next/
out/
.vercel/

# Generated at build time by scripts/fetch-data.mjs (~28MB JSON, would bloat
# the repo and go stale instantly since it's re-fetched fresh on every build).
public/data/restaurants.json
scripts/.data/

# Generated at build time by scripts/generate-og-images.mjs -- ~9,700 WebP
# images regenerated fresh each build; committing them would make this repo
# several hundred MB for no benefit (they're not source, they're output).
# home.webp is a hand-provided design asset, not build output -- keep it.
public/og/*.webp
!public/og/home.jpg

public/sitemap.xml
public/llms.txt

*.log
.DS_Store
